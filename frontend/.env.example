# Frontend local env (copy to .env.local — never commit secrets)

# Browser-facing backend URL (loopback only for lab)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Optional lab-only role token for local convenience. Prefer Settings → sessionStorage.
# Paste VIEWER/OPERATOR/APPROVER/ADMIN token — NEVER commit a real token.
# NEXT_PUBLIC_ADMIN_TOKEN=
