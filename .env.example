# =============================================================================
# INTERNAL DEV / MVP ENVIRONMENT — Ansible control server (on-prem only)
# =============================================================================
# Copy to .env on the internal Linux host:
#   cp .env.example .env
#
# This platform does NOT use AWS, Azure, GCP, or any public cloud APIs.
# All services run via Docker Compose on the internal Ansible control server.
# =============================================================================

# Application
APP_NAME=compliance-remediation-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-on-internal-server

# Bind published ports to loopback on the Ansible host (recommended).
# Use an internal NIC IP only if operators must reach the API from the LAN/VPN.
BIND_ADDRESS=127.0.0.1

# Optional internal container registry prefix, e.g. registry.corp.local/
# Leave empty if images are already present on the host / built locally.
INTERNAL_REGISTRY=
PYTHON_BASE_IMAGE=python:3.12-slim

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# PostgreSQL (compose service name: db)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=compliance
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_change_me
DATABASE_URL=postgresql+psycopg://compliance:compliance_change_me@db:5432/compliance

# Redis / Celery (compose service name: redis)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Host paths on the Ansible control server
DATA_DIR=./data
# Point at ./ansible (repo) OR an existing host tree, e.g. /etc/ansible
ANSIBLE_HOST_DIR=./ansible
# Directory containing the control-node SSH private key (never commit keys)
ANSIBLE_SSH_DIR=./data/ansible-ssh
ANSIBLE_PRIVATE_KEY_FILE=/opt/ansible-ssh/id_rsa
ANSIBLE_KNOWN_HOSTS=./data/ansible-ssh/known_hosts

# Paths inside containers
ANSIBLE_HOME=/opt/ansible
ANSIBLE_PLAYBOOKS_DIR=/opt/ansible/playbooks
ANSIBLE_INVENTORIES_DIR=/opt/ansible/inventories
UPLOAD_DIR=/var/lib/compliance/uploads
RUNNER_PRIVATE_DATA_DIR=/var/lib/compliance/ansible_private_data
TMP_INVENTORY_DIR=/var/lib/compliance/tmp_inventories

# Import / job defaults
EXCEL_CHUNK_SIZE=500
JOB_BATCH_SIZE=75

# AI Analyzer — mock/local only for MVP. Do not enable external SaaS AI.
AI_PROVIDER=mock
AI_ENABLED=false
# Optional later: internal/on-prem LLM endpoint only (never required for Ansible execution)
# AI_BASE_URL=http://127.0.0.1:11434
# AI_MODEL=
# AI_API_KEY=

# Frontend (optional profile)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
