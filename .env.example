# Application
APP_NAME=compliance-remediation-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# Required for all API routes except /health.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_TOKEN=change-me-set-a-strong-admin-token

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000

# PostgreSQL (published on 127.0.0.1 only via docker-compose)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=compliance
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_change_me
DATABASE_URL=postgresql+psycopg://compliance:compliance_change_me@db:5432/compliance

# Redis / Celery (published on 127.0.0.1 only via docker-compose)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Paths inside containers — host side is ./data and ./ansible (RO)
ANSIBLE_HOME=/opt/ansible
ANSIBLE_PLAYBOOKS_DIR=/opt/ansible/playbooks
ANSIBLE_INVENTORIES_DIR=/opt/ansible/inventories
# Default True. Set False only if you knowingly accept MITM risk on SSH.
ANSIBLE_HOST_KEY_CHECKING=True
UPLOAD_DIR=/var/lib/compliance/uploads
RUNNER_PRIVATE_DATA_DIR=/var/lib/compliance/ansible_private_data
TMP_INVENTORY_DIR=/var/lib/compliance/tmp_inventories

# Import / job defaults
EXCEL_CHUNK_SIZE=500
JOB_BATCH_SIZE=75

# Ansible execution mode
# true  = safe local/dev: AnsibleExecutionService returns fake per-host results
#         and NEVER runs ansible-runner or shell commands.
# false = reserved for the internal Ansible control server (real Runner later).
#         Do NOT set false until deployed on that host — see DEPLOYMENT.md.
MOCK_MODE=true

# AI Analyzer (disabled by default — interface only in Phase 1/4)
AI_PROVIDER=mock
AI_ENABLED=false
# AI_API_KEY=
# AI_BASE_URL=
# AI_MODEL=
