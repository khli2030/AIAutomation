# Application
APP_NAME=compliance-remediation-platform
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# PostgreSQL
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=compliance
POSTGRES_USER=compliance
POSTGRES_PASSWORD=compliance_change_me
DATABASE_URL=postgresql+psycopg://compliance:compliance_change_me@db:5432/compliance

# Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Paths inside containers (same-server Ansible mode)
ANSIBLE_HOME=/opt/ansible
ANSIBLE_PLAYBOOKS_DIR=/opt/ansible/playbooks
ANSIBLE_INVENTORIES_DIR=/opt/ansible/inventories
UPLOAD_DIR=/var/lib/compliance/uploads
RUNNER_PRIVATE_DATA_DIR=/var/lib/compliance/ansible_private_data
TMP_INVENTORY_DIR=/var/lib/compliance/tmp_inventories

# Import / job defaults
EXCEL_CHUNK_SIZE=500
JOB_BATCH_SIZE=75

# AI Analyzer (disabled by default — interface only in Phase 1/4)
AI_PROVIDER=mock
AI_ENABLED=false
# AI_API_KEY=
# AI_BASE_URL=
# AI_MODEL=
